        "inss = salario_bruto * 0.10\n",
        "fgts = salario_bruto * 0.11  # não desconta\n",
        "total_desc = ir + inss\n",
        "salario_liquido = salario_bruto - total_desc\n",
        "\n",
        "print(\"Salário Bruto:\", salario_bruto)\n",
        "print(\"IR (\", perc_ir, \"%):\", ir)\n",
