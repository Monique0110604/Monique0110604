        "\n",
        "# IR\n",
        "if salario_bruto <= 900:\n",
        "    ir = 0\n",
        "    perc_ir = 0\n",
        "elif salario_bruto <= 1500:\n",
        "    ir = salario_bruto * 0.05\n",
        "    perc_ir = 5\n",
        "elif salario_bruto <= 2500:\n",
        "    ir = salario_bruto * 0.10\n",
        "    perc_ir = 10\n",
        "else:\n",
        "    ir = salario_bruto * 0.20\n",
        "    perc_ir = 20\n",
